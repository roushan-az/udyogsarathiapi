
# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Udyog Sarathi"
APP_VERSION="1.0.0"
ENVIRONMENT="development"      # development | staging | production
DEBUG=true                     # Set false in production — disables dev bypass token
PORT=8000
WORKERS=1                      # Azure F1 is single-core

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="CHANGE_ME_USE_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS — React app origins (comma-separated) ────────────────────────────────
CORS_ORIGINS="http://localhost:3000,https://your-app.azurestaticapps.net"

# ── Azure PostgreSQL Flexible Server ─────────────────────────────────────────
# Async URL (used by SQLAlchemy at runtime)
DATABASE_URL="postgresql+asyncpg://udyog_admin:PASSWORD@udyog-db.postgres.database.azure.com:5432/udyog_sarathi?ssl=require"
# Sync URL (used by Alembic for migrations only)
DATABASE_SYNC_URL="postgresql+psycopg2://udyog_admin:PASSWORD@udyog-db.postgres.database.azure.com:5432/udyog_sarathi?sslmode=require"

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME="udyogsarathi"
AZURE_STORAGE_CONTAINER_NAME="documents"

# Option A — Connection string (recommended for App Service)
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=udyogsarathi;AccountKey=YOUR_KEY_HERE;EndpointSuffix=core.windows.net"

# Option B — Account key separately
AZURE_STORAGE_ACCOUNT_KEY=""

# Option C — Managed Identity (production recommended, no key needed)
USE_MANAGED_IDENTITY=false

# ── File Upload Limits ────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES="image/jpeg,image/png,image/webp,image/tiff,image/bmp"

# ── PDF Generation ────────────────────────────────────────────────────────────
PDF_IMAGE_QUALITY=95
PDF_DPI=150

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="INFO"
LOG_FORMAT="console"           # console (local) | json (production/Azure)
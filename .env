ENVIRONMENT=development


USE_LOCAL_STORAGE=True
LOCAL_UPLOAD_DIR=local_uploads
# Your local PostgreSQL connection string (asyncpg)
#DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/udyog_sarathi
DATABASE_URL=postgresql+asyncpg://postgres:admin@localhost:5432/udyog_sarathi
DATABASE_SYNC_URL=postgresql+psycopg://postgres:admin@localhost:5432/udyog_sarathi
# Azure Blob settings
AZURE_STORAGE_CONNECTION_STRING=your_azure_connection_string_here
AZURE_CONTAINER_NAME=documents
# JWT Security
SECRET_KEY=generate_a_long_random_string_here
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG=True
